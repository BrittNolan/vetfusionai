# ===== VetFusion marketing site — environment template =====
# Copy to .env.local and fill in. Do NOT put real secrets in this file.

# Site password gate (temporary "private preview" lock). Used by middleware.ts.
# Username is ignored; this is the password. Defaults to abc123! if unset.
SITE_PASSWORD=

# The clinical app (auth + accounts live there). The nav "Log in" links here.
# Defaults to https://app.vetfusion.ai if unset.
NEXT_PUBLIC_APP_URL=https://app.vetfusion.ai

# Supabase — contact inquiry form + future integration.
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=
